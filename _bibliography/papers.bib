% Single source of truth for publications (standard BibTeX).
% Rendered by scripts/bib2yaml.rb -> _data/publications.yml (run after edits).
% Conventions:
%   type -> section:  @article=manuscripts, @inproceedings=conferences,
%                      @phdthesis=thesis, @unpublished=underreview
%   corresponding = {Surname}   -> that author gets * (journals only)
%   date = {YYYY-MM-DD}         -> ordering key (stable within a year)
%   note = {...}                -> award/honor, shown at END OF TITLE (visible)
%   presentation = {...}        -> e.g. "Extended Abstract", shown at title (muted)
%   abstract = {...}            -> short summary, shown only for @article
%   eventdate / address         -> conference dates / location
%   doi or url                  -> becomes the title hyperlink (not in citation)

